<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!-- Settings-dialog profiles (S158). Deliberately minimal: every one extends a
     stock base-game fs25_* / baseReference profile and overrides only spacing,
     size or text metrics, the exact idiom AutoDrive's guiProfiles.xml uses
     (ad_common_dialog*). A new dialog needs almost no custom profile surface
     because the base game already ships the dialog chrome and button styles. -->
<GUIProfiles>
    <Profile name="fm25_dialogContentContainer" extends="fs25_dialogContentContainer">
        <flowDirection value="vertical" />
        <elementSpacing value="10px" />
        <alignmentX value="center" />
    </Profile>

    <Profile name="fm25_dialogTitle" extends="baseReference" with="anchorTopStretchingX">
        <textBold value="true"/>
        <textLayoutMode value="resize" />
        <textMaxNumLines value="1" />
        <textSize value="24px"/>
        <textUpperCase value="true"/>
        <size value="100% 40px"/>
    </Profile>

    <Profile name="fm25_dialogTitleSeparator" extends="fs25_lineSeparatorTop">
        <absoluteSizeOffset value="100px 0" />
    </Profile>

    <!-- A native settings row: title (left) + a ‹value› MultiTextOption stepper
         (right) + tooltip, the exact idiom Distribution Redux uses
         (DistributionSettingsPage.xml). The row container / stepper / title /
         tooltip profiles are all stock base-game (fs25_multiTextOption*), so
         this is the only local profile the redesign needs; it just constrains
         the stock container (tuned for the wide in-game menu frame) to the
         740px dialog's content width. -->
    <Profile name="fm25_settingsRow" extends="fs25_multiTextOptionContainer" with="anchorTopStretchingX">
        <size value="100% 56px"/>
    </Profile>

    <!-- The one remaining button: Reset panel position (an action, not a value,
         so it stays a button rather than a stepper). Extends the stock dialog
         button; only size + text metrics overridden. -->
    <Profile name="fm25_settingButton" extends="buttonActivate" with="anchorTopStretchingX">
        <size value="100% 42px"/>
        <textSize value="18px"/>
    </Profile>

    <Profile name="fm25_dialogButtonBox" extends="fs25_dialogButtonBox">
    </Profile>
</GUIProfiles>
